# Application configuration
APP_PASSWORD=

# Database configuration
HOST=127.0.0.1
DB_NAME=invoice_db
DB_USER=root
DB_PASSWORD=

# Local files vs S3 storage configurations
# For local storage, set S3_BASE_URL to /uploads/ and leave AWS keys empty.
# Uploads will be saved locally inside a folder named 'uploads' in the root directory.
S3_BASE_URL=/uploads/

# Optional: AWS S3 storage configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1
